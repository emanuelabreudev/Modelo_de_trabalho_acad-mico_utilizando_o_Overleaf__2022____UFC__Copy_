# PDFs e arquivos gerados (opcional)
# --------------------------
# Ignora todos os PDFs (comente se quiser subir o PDF final)
*.pdf

# Se quiser manter um PDF final específico, por exemplo "documento.pdf",
# use (descomente a linha abaixo e comente a linha *.pdf acima):
# !/documento.pdf

